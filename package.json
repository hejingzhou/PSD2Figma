{
  "name": "psd-to-figma-converter",
  "version": "1.0.0",
  "description": "Convert PSD files to editable Figma designs",
  "scripts": {
    "build": "npm run build:ui && npm run build:code",
    "build:ui": "vite build",
    "build:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es6",
    "watch": "npm run watch:ui & npm run watch:code",
    "watch:ui": "vite build --watch",
    "watch:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es6 --watch",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "ag-psd": "^16.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.84.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "canvas": "^3.2.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-singlefile": "^0.13.5",
    "vitest": "^1.0.0"
  }
}
